{
  "name": "@softwarestartups/exacli",
  "version": "1.2.0",
  "description": "A CLI tool for Exa AI search API",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "exacli": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "!build/**/*.map"
  ],
  "scripts": {
    "build": "tsc",
    "start": "bun run build/index.js",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "lint": "bunx biome lint .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "bun test",
    "prepare": "lefthook install || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftwareStartups/exacli.git"
  },
  "bugs": {
    "url": "https://github.com/SoftwareStartups/exacli/issues"
  },
  "homepage": "https://github.com/SoftwareStartups/exacli#readme",
  "keywords": [
    "exa",
    "ai",
    "search",
    "cli",
    "semantic-search"
  ],
  "author": "SoftwareStartups",
  "license": "MIT",
  "dependencies": {
    "exa-js": "2.12.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "bun-types": "1.3.13",
    "lefthook": "2.1.6",
    "typescript": "6.0.3"
  }
}
